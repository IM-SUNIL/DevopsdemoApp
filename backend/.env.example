# =========================================================================
# Backend Environment Configuration Template
# Copy this file to '.env' and adjust variables to suit your environment.
# Do not commit real production secrets to version control.
# =========================================================================

# The port number the Express server listens on.
# Default: 5000
PORT=5000

# The operational mode of the application environment.
# Options: 'development', 'production', 'test'
# Default: 'development'
NODE_ENV=development

# The absolute origin URL of the client application.
# Used to enable cross-origin resource sharing (CORS).
# Default: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# The connection string for the PostgreSQL database (used by Prisma).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Default (for local running when Docker is not used):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskmanager?schema=public"
